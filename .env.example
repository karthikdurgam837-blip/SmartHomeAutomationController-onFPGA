# GEMINI_API_KEY: Required for Gemini AI API calls.
# The platform automatically injects this at runtime from user secrets.
# Users configure this via their administrative dashboard or project configuration.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this server is hosted.
# The platform automatically injects this at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
